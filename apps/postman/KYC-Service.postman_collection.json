        {
          "name": "Health — aggregate",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{kycBaseUrl}}/q/health", "host": ["{{kycBaseUrl}}"], "path": ["q", "health"] },
            "description": "SmallRye Health roll-up of all checks, including the custom `OutboxBacklogHealthCheck`."
          },
          "response": []
        },
        {
          "name": "Health — liveness",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{kycBaseUrl}}/q/health/live", "host": ["{{kycBaseUrl}}"], "path": ["q", "health", "live"] },
            "description": "Liveness probe — \"is the process alive?\" (Kubernetes restarts on failure)."
          },
          "response": []
        },
        {
          "name": "Health — readiness",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{kycBaseUrl}}/q/health/ready", "host": ["{{kycBaseUrl}}"], "path": ["q", "health", "ready"] },
            "description": "Readiness probe — \"can it serve traffic?\" Includes the datasource check (DB reachable)."
          },
          "response": []
        },
        {
          "name": "Health — started",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{kycBaseUrl}}/q/health/started", "host": ["{{kycBaseUrl}}"], "path": ["q", "health", "started"] },
            "description": "Startup probe — \"has the app finished booting?\""
          },
          "response": []
        },
        {
          "name": "Prometheus metrics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/plain" }],
            "url": { "raw": "{{kycBaseUrl}}/q/metrics", "host": ["{{kycBaseUrl}}"], "path": ["q", "metrics"] },
            "description": "Micrometer/Prometheus scrape endpoint. After registering, look for `applicants_registered_total` and the HTTP server timers."
          },
          "response": []
        }
      ],
      "description": "Operational endpoints exposed by SmallRye Health + Micrometer."
    }
  ],
